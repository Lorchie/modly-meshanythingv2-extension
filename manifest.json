{
  "id": "meshanythingv2",
  "name": "MeshAnythingV2",
  "source": "https://github.com/lightningpixel/modly-meshanythingv2-extension",
  "description": "Converts any raw 3D mesh into a clean, CAD-ready mesh using MeshAnythingV2.",
  "version": "1.0.0",
  "author": "Lorchie",
  "generator_class": "MeshAnythingV2Generator",
  "tags": ["mesh-to-mesh", "topology", "remesh"],
  "nodes": [
    {
      "id": "generate",
      "name": "MeshAnythingV2",
      "input": "mesh",
      "output": "mesh",
      "params_schema": [
        { "id": "face_number", "type": "int", "default": 800 },
        { "id": "mc", "type": "bool", "default": true },
        { "id": "mc_level", "type": "int", "default": 7 },
        { "id": "no_pc_vertices", "type": "int", "default": 8192 },
        { "id": "sampling", "type": "bool", "default": false },
        { "id": "seed", "type": "int", "default": 0 }
      ]
    },
    {
      "id": "preprocess",
      "name": "Preprocess",
      "input": "mesh",
      "output": "mesh",
      "params_schema": [
        { "id": "mc_level", "type": "int", "default": 7 }
      ]
    }
  ]
}